{{ if and (eq .chezmoi.os "linux") (not .transient) -}}

#!/bin/bash

# Install system requirements

{{ if (eq .osid "linux-fedora" "linux-nobara") }}
  sudo dnf install -y cargo automake libtool
{{ end }}

{{ if (eq .osid "linux-ubuntu" "linux-pop") }}
  sudo apt install -y automake
{{ end }}
  
# Install rustup (which also installs cargo)
curl https://sh.rustup.rs -sSf | sh

# For now, in order for cargo to be found in this script 
# we need to manually configure the current shell 
# (which is bash as we've specified that at the top)
. "$HOME/.cargo/env"

cargo install jnv   # interactive 'jq'

{{ end -}}
